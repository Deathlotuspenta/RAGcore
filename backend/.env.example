LLM_MODEL_NAME=deepseek-chat
EMBEDDING_MODEL_NAME=models/bge-small-zh-v1.5
LLM_MODEL_URL=https://api.deepseek.com/v1/chat/completions
EMBEDDING_MODEL_URL=https://api.deepseek.com/v1/embeddings
LLM_MODEL_API_KEY=your-deepseek-api-key-here
CHROMA_PERSIST_DIR=storage/chroma
DB_PATH=storage/metadata.db

JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:8765

# 上传文件大小上限（MB）
MAX_UPLOAD_MB=10

# 重排序（BGE CrossEncoder）
RERANK_ENABLED=true
RERANK_MODEL_NAME=models/bge-reranker-base
RERANK_CANDIDATES=20
